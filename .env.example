# Sigma SMS A2P - Python Version
# Environment Configuration

# Application
APP_NAME=Sigma SMS A2P
APP_ENV=production
APP_DEBUG=False
APP_URL=https://your-domain.com
SECRET_KEY=generate-random-secret-key-here-use-openssl-rand-hex-32

# Database
DATABASE_URL=mysql+pymysql://sigma_user:your_password@localhost/sigma_sms_a2p
# Or PostgreSQL:
# DATABASE_URL=postgresql://sigma_user:your_password@localhost/sigma_sms_a2p

# Redis (for caching and sessions)
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET_KEY=generate-another-random-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Rate Limiting
RATE_LIMIT_LOGIN=5/15minutes
RATE_LIMIT_API=100/hour
RATE_LIMIT_WEBHOOK=1000/hour

# CORS
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Session
SESSION_LIFETIME=3600
SESSION_COOKIE_NAME=sigma_session

# Test Panel
TEST_DEFAULT_USERNAME=test123
TEST_DEFAULT_PASSWORD=test123
TEST_DEFAULT_LIMIT=10

# Crypto
USDT_TRC20_MIN_PAYOUT=10.00
BINANCE_MIN_PAYOUT=10.00

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@your-domain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/sigma-sms/app.log
