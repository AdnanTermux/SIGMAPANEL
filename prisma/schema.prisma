generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== USERS ====================
model User {
  id                  String    @id @default(cuid())
  username            String    @unique
  email               String?   @unique
  password            String
  role                String    @default("admin") // admin, manager, reseller, sub_reseller
  status              String    @default("active") // active, blocked
  parentId            String?
  fullName            String?
  balance             Float     @default(0)
  creditLimit         Float     @default(0)
  phone               String?
  country             String?
  timezone            String    @default("UTC")
  language            String    @default("en")
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLogin           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  parent              User?     @relation("UserHierarchy", fields: [parentId], references: [id])
  children            User[]    @relation("UserHierarchy")
  settings            Settings[]
}

// ==================== RANGES ====================
model Range {
  id                     String   @id @default(cuid())
  name                   String   @unique
  providerId             String?
  countryCode            String?
  countryName            String?
  rate                   Float    @default(0)
  profitMargin           Float    @default(0)
  otpLimitPerDay         Int      @default(0)
  otpDailyResetHour      Int      @default(0)
  allocationLimitGlobal  Int      @default(10000)
  allocationLimitPerUser Int      @default(100)
  allocationPeriod       String   @default("daily") // daily, weekly, monthly
  status                 String   @default("active") // active, inactive, maintenance
  totalNumbers           Int      @default(0)
  allocatedNumbers       Int      @default(0)
  totalSms               Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  numbers                Number[]
}

// ==================== NUMBERS ====================
model Number {
  id           String    @id @default(cuid())
  number       String    @unique
  country      String?
  countryName  String?
  rangeName    String?
  rangeId      String?
  service      String?
  status       String    @default("active") // active, inactive, maintenance
  assignedTo   String?   // username
  assignedAt   DateTime?
  rate         Float     @default(0)
  profitMargin Float     @default(0)
  totalSms     Int       @default(0)
  lastSmsAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  range        Range?    @relation(fields: [rangeId], references: [id])
  smsReceived  SmsReceived[]
}

// ==================== SMS RECEIVED ====================
model SmsReceived {
  id          String    @id @default(cuid())
  number      String
  from        String?   // Service/sender name (Google, WhatsApp, etc.)
  to          String?   // Recipient number (where OTP was sent)
  service     String?
  country     String?
  rangeName   String?
  otp         String?
  message     String
  assignedTo  String?
  currency    String    @default("USD")
  rate        Float     @default(0)
  profit      Float     @default(0)
  receivedAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  numberModel Number?   @relation(fields: [number], references: [number])
}

// ==================== SETTINGS ====================
model Settings {
  id           String @id @default(cuid())
  settingKey   String @unique
  settingValue String
  userId       String?
  user         User?  @relation(fields: [userId], references: [id])
}

// ==================== NOTIFICATIONS ====================
model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  message   String
  type      String?  @default("info") // info, warning, success, error
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}

// ==================== PROFIT LOG ====================
model ProfitLog {
  id            String   @id @default(cuid())
  userId        String?
  numberId      String?
  smsReceivedId String?
  rateApplied   Float    @default(0)
  profitAmount  Float    @default(0)
  currency      String   @default("USD")
  createdAt     DateTime @default(now())
}
